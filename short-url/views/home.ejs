<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>
    <style>
        /* Modern UI Styles */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }

        h1 {
            color: #333;
            margin-bottom: 30px;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 800px;
        }

        /* Form Styling */
        form {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            align-items: center;
        }

        input[type="text"] {
            flex: 1;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 6px;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        input[type="text"]:focus {
            border-color: #4A90E2;
            outline: none;
        }

        button {
            padding: 12px 24px;
            background-color: #4A90E2;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.3s;
        }

        button:hover {
            background-color: #357ABD;
        }

        /* Result Alert */
        .result {
            margin: 20px 0;
            padding: 15px;
            background-color: #e7f3ff;
            border-left: 5px solid #4A90E2;
            border-radius: 4px;
            word-break: break-all;
        }

        /* Table Styling */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            background: white;
        }

        th,
        td {
            text-align: left;
            padding: 14px;
            border-bottom: 1px solid #eee;
        }

        th {
            background-color: #f8f9fa;
            color: #666;
            text-transform: uppercase;
            font-size: 13px;
            letter-spacing: 1px;
        }

        tr:hover {
            background-color: #fdfdfd;
        }

        .all-urls {
            overflow-x: auto;
        }
    </style>
</head>

<body>
 <nav style="
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    padding: 12px 24px; 
    background-color: #0f172a; 
    border-bottom: 1px solid #1e293b; 
    font-family: sans-serif;
        gap: 26px;
">
    <div style="display: flex; align-items: center; gap: 12px;">
        <div style="
            background: #3b82f6; 
            width: 36px; 
            height: 36px; 
            border-radius: 8px; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            color: white; 
            font-weight: bold;
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
        ">S</div>
        <span style="color: #ffffff; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.5px;">ShortURL</span>
    </div>

    <div style="display: flex; align-items: center; gap: 34px;">
        <% if (locals.user) { %>
            <div style="display: flex; align-items: center; gap: 32px;">
                <div style="display: flex; flex-direction: column; align-items: flex-end;">
                    <span style="font-size: 10px; color: #64748b; text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px;">User</span>
                    <span style="font-size: 14px; color: #e2e8f0; font-weight: 600;"><%= user.username %></span>
                </div>
                <div style="
                    width: 40px; 
                    height: 40px; 
                    background: #1e293b; 
                    border: 1px solid #334155; 
                    border-radius: 50%; 
                    display: flex; 
                    align-items: center; 
                    justify-content: center; 
                    color: #3b82f6; 
                    font-weight: bold;
                    font-size: 18px;
                ">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>
            </div>
            
            <a href="/user/logout" style="
                background-color: rgba(239, 68, 68, 0.1); 
                color: #f87171; 
                padding: 10px 18px; 
                border-radius: 8px; 
                border: 1px solid rgba(239, 68, 68, 0.3);
                text-decoration: none; 
                font-size: 14px; 
                font-weight: 600;
                transition: 0.3s;
            " onmouseover="this.style.backgroundColor='#ef4444'; this.style.color='white';" 
               onmouseout="this.style.backgroundColor='rgba(239, 68, 68, 0.1)'; this.style.color='#f87171';">
                Logout
            </a>
        <% } %>
    </div>
</nav>
    <h1>URL Shortener</h1>

    <div class="container">
        <!-- Input Section -->
        <form method="POST" action="/url">
            <label for="Url"><strong>Enter URL:</strong></label>
            <input type="text" name="url" placeholder="https://example.com" required>
            <button type="submit">Shorten</button>
        </form>

        <!-- Success Message -->
        <div class="result">
            <% if (locals.id) { %>
                <p><strong>Success!</strong> Your Short URL is: <a href="http://localhost:5000/url/<%= id %>"
                        target="_blank">localhost:5000/url/<%= id %></a></p>
                <% } %>

        </div>

        <!-- History Table -->
        <div class="all-urls">
            <% if (locals.allUrls) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Sr.no</th>
                            <th>Short Id</th>
                            <th>Original URL</th>
                            <th>Clicks</th>
                            <th>Analysis</th>
                            <th>Delete Url</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% allUrls.forEach((url,index)=> { %>
                            <tr>
                                <td>
                                    <%= index+1 %>
                                </td>
                                <td><code><%= url.shortId %></code></td>
                                <td style="color: #666;">
                                    <%= url.redirectUrl %>
                                </td>
                                <td><strong>
                                        <%= url.visitHistory.length %>
                                    </strong></td>
                                <td>
                                    <a href="http://localhost:5000/url/analysis/<%=url.shortId %>">Analysis</a>
                                </td>
                                <td style="text-align: center; vertical-align: middle;">
                                    <form method="POST" action="/url/delete/<%= url.shortId %>"
                                        onsubmit="return confirm('Are you sure you want to delete this URL?');"
                                        style="display: inline-block; margin: 0;">

                                        <button type="submit"
                                            style="background-color: #ff4d4d; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer;">
                                            Delete
                                        </button>

                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
                <% } %>
        </div>
    </div>

</body>

</html>