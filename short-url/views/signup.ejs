<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - URL Shortener</title>

    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

    <style>
        /* Base Reset */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: #f8fafc;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            background: #ffffff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            width: 100%;
            max-width: 400px;
        }

        h2 {
            text-align: center;
            color: #1e293b;
            margin-bottom: 24px;
            font-size: 1.5rem;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 500;
            color: #64748b;
            margin-bottom: 8px;
        }

        input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 1rem;
            transition: all 0.2s ease;
            outline: none;
        }

        input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        button {
            width: 100%;
            padding: 12px;
            background-color: #3b82f6;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 10px;
        }

        button:hover {
            background-color: #2563eb;
        }

        button:active {
            transform: scale(0.98);
        }

        .login-text {
            text-align: center;
            margin-top: 20px;
            font-size: 0.875rem;
            color: #64748b;
        }

        .login-text a {
            color: #3b82f6;
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="container">
        <h2>Create Account</h2>

        <form id="signupForm">
            <div class="form-group">
                <label for="username">Full Name</label>
                <input type="text" id="username" name="username" placeholder="John Doe" required>
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="name@company.com" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
            </div>
            <button type="submit" id="submitBtn">Sign Up</button>
        </form>

        <div class="login-text">
            Already have an account? <a href="/login">Log in</a>
        </div>
    </div>

    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

    <script>
        document.getElementById('signupForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const submitBtn = document.getElementById('submitBtn');
            submitBtn.innerText = "Processing...";
            submitBtn.disabled = true;

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            try {
                const response = await fetch('/user/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                // 1. This parses the JSON body from the server
                const result = await response.json();
                if (response.ok) {
                    Toastify({
                        text: "✔ Account created! Redirecting to login...",
                        duration: 4000,
                        gravity: "top",
                        position: "center",
                        stopOnFocus: true,
                        style: {
                            background: "#059669",
                            borderRadius: "8px"
                        }
                    }).showToast();

                    setTimeout(() => {
                        window.location.href = "/login";
                    }, 4000);
                } else {
                    // This will show "Email already exists", "Name already exists", etc.
                    Toastify({
                        text: result.error || "Signup Failed",
                        duration: 5000,
                        gravity: "top",
                        position: "center",
                        style: {
                            background: "#ff5f6d", // Red for error
                            borderRadius: "8px"
                        }
                    }).showToast();
                    submitBtn.innerText = "Sign Up";
                    submitBtn.disabled = false;
                    // 2. Clear the form fields so the user can try again
                    e.target.reset();

                    // Optional: Put the cursor back in the first box automatically
                    e.target.querySelector('input[name="username"]').focus();
                }
            } catch (err) {
                console.error("Error:", err);
                submitBtn.innerText = "Sign Up";
                submitBtn.disabled = false;
            }
        });
    </script>

</body>

</html>